@model IEnumerable<TerralexApp.Models.Property>
@{
    ViewData["Title"] = "Properties Catalog";
    Layout = "_DashboardLayout";
}

<!-- Filters & Actions Header -->
<div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
    <form method="get" asp-controller="Properties" asp-action="Index" class="row g-3 align-items-end">
        <div class="col-md-4">
            <label class="form-label-premium">Search Address / District</label>
            <div class="input-group">
                <span class="input-group-text bg-white border-end-0 border-radius-10"><i class="bi bi-search text-muted"></i></span>
                <input type="text" name="searchString" value="@Context.Request.Query["searchString"]" class="form-control form-control-premium border-start-0" placeholder="e.g. Nasr City, Cairo..." />
            </div>
        </div>
        <div class="col-md-3">
            <label class="form-label-premium">City</label>
            <select name="cityId" asp-items="ViewBag.Cities" class="form-select form-control-premium">
                <option value="">All Cities</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label-premium">Property Type</label>
            <select name="propertyTypeId" asp-items="ViewBag.PropertyTypes" class="form-select form-control-premium">
                <option value="">All Types</option>
            </select>
        </div>
        <div class="col-md-2 d-flex gap-2">
            <button type="submit" class="btn btn-premium btn-premium-primary w-100 justify-content-center">
                <i class="bi bi-funnel"></i> Filter
            </button>
            <a href="@Url.Action("Create", "Properties")" class="btn btn-premium btn-premium-success justify-content-center">
                <i class="bi bi-plus-lg"></i> Add
            </a>
        </div>
    </form>
</div>

<!-- Properties Grid -->
@if (Model == null || !Model.Any())
{
    <div class="card border-0 shadow-sm rounded-4 p-5 text-center text-muted">
        <i class="bi bi-building-exclamation display-3 text-warning mb-3"></i>
        <h3>No Properties Found</h3>
        <p class="mb-0">Try adjusting your filters or click "Add" to register a new property transaction.</p>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var property in Model)
        {
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100 transition-smooth hover-translate-y">
                    <!-- Property Main Image/Placeholder -->
                    <div class="position-relative" style="height: 200px; background-color: #f1f5f9;">
                        @{
                            var primaryImg = property.PropertyImages?.FirstOrDefault(i => !i.IsDeleted);
                        }
                        @if (primaryImg != null)
                        {
                            <img src="@primaryImg.ImagePath" class="w-100 h-100 object-fit-cover" alt="Property Photo" />
                        }
                        else
                        {
                            <div class="w-100 h-100 d-flex flex-column align-items-center justify-content-center text-muted">
                                <i class="bi bi-building display-5 mb-2 text-secondary"></i>
                                <span class="fs-7">No photos uploaded</span>
                            </div>
                        }
                        <span class="badge bg-primary position-absolute top-3 start-3 px-3 py-2 rounded-pill shadow-sm">
                            @property.PropertyType.Name
                        </span>
                    </div>

                    <!-- Card Body -->
                    <div class="card-body p-4 d-flex flex-column">
                        <h5 class="card-title fw-bold text-dark mb-1">@property.District</h5>
                        <p class="card-text text-muted fs-7 mb-3"><i class="bi bi-geo-alt-fill text-danger me-1"></i>@property.Address, @property.City.Name</p>
                        
                        <!-- Layout Specs -->
                        <div class="row g-2 mb-4 text-center border-top border-bottom py-2">
                            <div class="col-4 border-end">
                                <div class="fw-bold text-dark">@property.Area.ToString("N0")</div>
                                <small class="text-muted fs-8 uppercase">Sqm</small>
                            </div>
                            <div class="col-4 border-end">
                                <div class="fw-bold text-dark">@(property.Rooms ?? 0)</div>
                                <small class="text-muted fs-8 uppercase">Rooms</small>
                            </div>
                            <div class="col-4">
                                <div class="fw-bold text-dark">@(property.Bathrooms ?? 0)</div>
                                <small class="text-muted fs-8 uppercase">Baths</small>
                            </div>
                        </div>

                        <!-- Footer Actions -->
                        <div class="d-flex justify-content-between align-items-center mt-auto">
                            <a href="@Url.Action("Details", "Properties", new { id = property.PropertyId })" class="btn btn-sm btn-outline-primary rounded-pill px-4 fw-semibold">View Details</a>
                            <div class="d-flex gap-1">
                                <a href="@Url.Action("Edit", "Properties", new { id = property.PropertyId })" class="btn btn-sm btn-light text-warning" title="Edit"><i class="bi bi-pencil-fill"></i></a>
                                <form method="post" asp-controller="Properties" asp-action="Delete" asp-route-id="@property.PropertyId" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this property?');">
                                    <button type="submit" class="btn btn-sm btn-light text-danger" title="Delete"><i class="bi bi-trash-fill"></i></button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<style>
    .hover-translate-y {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .hover-translate-y:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
    .fs-7 { font-size: 0.85rem; }
    .fs-8 { font-size: 0.72rem; }
    .object-fit-cover { object-fit: cover; }
    .top-3 { top: 1rem; }
    .start-3 { left: 1rem; }
</style>
