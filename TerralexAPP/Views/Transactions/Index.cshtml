@model IEnumerable<TerralexApp.Models.Transaction>
@{
    ViewData["Title"] = "Real Estate Transactions";
    Layout = "_DashboardLayout";
}

<!-- Filter Panel & Actions Header -->
<div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
    <form method="get" asp-controller="Transactions" asp-action="Index" class="row g-3 align-items-end">
        <div class="col-md-4">
            <label class="form-label-premium">Client</label>
            <select name="clientId" asp-items="ViewBag.Clients" class="form-select form-control-premium">
                <option value="">All Clients</option>
            </select>
        </div>
        <div class="col-md-4">
            <label class="form-label-premium">Status</label>
            <select name="statusId" asp-items="ViewBag.Statuses" class="form-select form-control-premium">
                <option value="">All Statuses</option>
            </select>
        </div>
        <div class="col-md-4 d-flex gap-2">
            <button type="submit" class="btn btn-premium btn-premium-primary w-100 justify-content-center">
                <i class="bi bi-funnel"></i> Filter
            </button>
            <a href="@Url.Action("Create", "Transactions")" class="btn btn-premium btn-premium-success w-100 justify-content-center">
                <i class="bi bi-plus-lg"></i> New Deal
            </a>
        </div>
    </form>
</div>

<!-- Transactions Table List -->
<div class="table-card">
    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-file-earmark-lock display-3 text-warning mb-3"></i>
            <h3>No Transactions Logged</h3>
            <p class="mb-0">Click "New Deal" to initiate a real estate lawyer transaction timeline.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table-premium table align-middle">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Client</th>
                        <th>Property</th>
                        <th>Service Type</th>
                        <th>Lawyer</th>
                        <th>Dates</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var deal in Model)
                    {
                        <tr>
                            <td><strong>#@deal.TransactionId</strong></td>
                            <td>
                                <div class="fw-semibold text-dark">@deal.Client.FirstName @deal.Client.LastName</div>
                                <small class="text-muted">@deal.Client.Email</small>
                            </td>
                            <td>
                                <div class="text-dark fw-medium">@deal.Property.District</div>
                                <small class="text-muted">@deal.Property.Address</small>
                            </td>
                            <td>
                                <span class="fw-medium text-dark">@deal.ServiceType.Name</span>
                            </td>
                            <td>
                                <div class="text-dark">@deal.Stuff.Name</div>
                                <small class="text-muted">@deal.Stuff.JobTitle</small>
                            </td>
                            <td>
                                <div class="fs-7 text-dark"><i class="bi bi-calendar-check me-1 text-success"></i>@deal.StarDate.ToString("d")</div>
                                <div class="fs-7 text-muted"><i class="bi bi-calendar-x me-1 text-danger"></i>@deal.EndDate.ToString("d")</div>
                            </td>
                            <td>
                                @{
                                    var badgeClass = "badge-primary";
                                    if (deal.TransactionStatus.Name == "Registered") badgeClass = "badge-success";
                                    else if (deal.TransactionStatus.Name == "Closed") badgeClass = "badge-danger";
                                    else if (deal.TransactionStatus.Name == "In Progress") badgeClass = "badge-warning";
                                    else if (deal.TransactionStatus.Name == "Pending Signature") badgeClass = "badge-info";
                                }
                                <span class="badge-premium @badgeClass">@deal.TransactionStatus.Name</span>
                            </td>
                            <td class="text-end">
                                <div class="d-inline-flex gap-1">
                                    <a href="@Url.Action("Details", "Transactions", new { id = deal.TransactionId })" class="btn btn-sm btn-outline-primary" title="View Stages & Details"><i class="bi bi-eye-fill"></i> Details</a>
                                    @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                                    {
                                        <a href="@Url.Action("Edit", "Transactions", new { id = deal.TransactionId })" class="btn btn-sm btn-light text-warning" title="Edit Properties"><i class="bi bi-pencil-fill"></i></a>
                                        <form method="post" asp-controller="Transactions" asp-action="Delete" asp-route-id="@deal.TransactionId" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this transaction record?');">
                                            <button type="submit" class="btn btn-sm btn-light text-danger" title="Delete"><i class="bi bi-trash-fill"></i></button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<style>
    .fs-7 { font-size: 0.85rem; }
</style>
