@model IEnumerable<TerralexApp.Models.Template>
@{
    Layout = "_DashboardLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0 text-gray-800">Legal Contract Templates</h1>
        <p class="text-muted small mb-0">Store and manage standardized lawyer contract templates for reuse.</p>
    </div>
    <a asp-action="Create" class="btn btn-premium btn-premium-primary">
        <i class="bi bi-file-earmark-arrow-up-fill"></i> Upload Template
    </a>
</div>

<!-- Templates Grid Layout -->
<div class="row g-4">
    @if (!Model.Any())
    {
        <div class="col-12 text-center py-5 text-muted card shadow-sm">
            <i class="bi bi-file-earmark-excel" style="font-size: 3rem; display: block; margin-bottom: 1rem;"></i>
            No contract templates uploaded yet. Create one to get started.
        </div>
    }
    else
    {
        foreach (var item in Model)
        {
            var isPdf = item.TemplateContentPath.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase);
            var isWord = item.TemplateContentPath.EndsWith(".doc", StringComparison.OrdinalIgnoreCase) || 
                          item.TemplateContentPath.EndsWith(".docx", StringComparison.OrdinalIgnoreCase);

            <div class="col-md-4">
                <div class="stat-card" style="--card-accent: @(isPdf ? "var(--danger)" : "var(--info)");">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="stat-card-icon" style="background-color: @(isPdf ? "var(--danger-light)" : "var(--info-light)"); color: @(isPdf ? "var(--danger)" : "var(--info)");">
                            <i class="bi @(isPdf ? "bi-filetype-pdf" : (isWord ? "bi-filetype-docx" : "bi-file-earmark-text"))"></i>
                        </div>
                        <div class="dropdown no-print">
                            <button class="btn btn-sm btn-link text-muted p-0" type="button" id="menu-@item.TemplateId" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-three-dots-vertical" style="font-size: 1.2rem;"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow-sm" aria-labelledby="menu-@item.TemplateId">
                                @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                                {
                                    <li>
                                        <a asp-action="Edit" asp-route-id="@item.TemplateId" class="dropdown-item text-warning">
                                            <i class="bi bi-pencil-square me-2"></i>Edit
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-action="Delete" asp-route-id="@item.TemplateId" method="post" onsubmit="return confirm('Are you sure you want to delete this template?');">
                                            <button type="submit" class="dropdown-item text-danger">
                                                <i class="bi bi-trash-fill me-2"></i>Delete
                                            </button>
                                        </form>
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>

                    <h5 class="fw-bold text-dark text-truncate mb-1" title="@item.TemplateName">@item.TemplateName</h5>
                    <p class="text-muted small mb-3">Stored: @System.IO.Path.GetFileName(item.TemplateContentPath)</p>
                    
                    <a href="@item.TemplateContentPath" download class="btn btn-premium btn-premium-secondary btn-sm w-100 mt-2 justify-content-center">
                        <i class="bi bi-cloud-arrow-down-fill"></i> Download Template
                    </a>
                </div>
            </div>
        }
    }
</div>
