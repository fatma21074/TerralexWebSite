@model List<Client>

@{
    ViewData["Title"] = "Clients";
    Layout = "_DashboardLayout";
}

<div class="row">
    <div class="col-md-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Clients</h1>
            <a href="@Url.Action("CreateClient", "Dashboard")" class="btn btn-primary">Add New Client</a>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-body">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>National ID</th>
                            <th>Client Type</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Count > 0)
                        {
                            @foreach (var client in Model)
                            {
                                <tr>
                                    <td>@client.ClientId</td>
                                    <td>@client.FirstName @client.LastName</td>
                                    <td>@client.Email</td>
                                    <td>@client.Mobile</td>
                                    <td>@client.NationalId</td>
                                    <td>@client.ClientType</td>
                                    <td>
                                        <a href="@Url.Action("ViewClient", "Dashboard", new { id = client.ClientId })" class="btn btn-sm btn-info">View</a>
                                        <a href="@Url.Action("EditClient", "Dashboard", new { id = client.ClientId })" class="btn btn-sm btn-warning">Edit</a>
                                        <form asp-action="DeleteClient" asp-controller="Dashboard" method="post" style="display:inline;">
                                            <input type="hidden" name="id" value="@client.ClientId" />
                                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure you want to delete this client?')">Delete</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">No clients added yet.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

