@model Client

@{
    ViewData["Title"] = "Edit Client";
    Layout = "_DashboardLayout";
}

<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="card">
            <div class="card-header">
                <h4>Edit Client</h4>
            </div>
            <div class="card-body">
                <form asp-action="EditClient" asp-controller="Dashboard" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="ClientId" />
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="FirstName" class="form-label"></label>
                            <input asp-for="FirstName" class="form-control" />
                            <span asp-validation-for="FirstName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="LastName" class="form-label"></label>
                            <input asp-for="LastName" class="form-control" />
                            <span asp-validation-for="LastName" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="NationalId" class="form-label"></label>
                            <input asp-for="NationalId" class="form-control" />
                            <span asp-validation-for="NationalId" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Mobile" class="form-label"></label>
                            <input asp-for="Mobile" class="form-control" />
                            <span asp-validation-for="Mobile" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" type="email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Address" class="form-label"></label>
                        <textarea asp-for="Address" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Address" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ClientType" class="form-label"></label>
                        <select asp-for="ClientType" class="form-control">
                            <option value="">-- Select Client Type --</option>
                            <option value="Individual">Individual</option>
                            <option value="Company">Company</option>
                            <option value="Government">Government</option>
                        </select>
                        <span asp-validation-for="ClientType" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            @if (!string.IsNullOrEmpty(Model.IDImageFrontPath))
                            {
                                <div class="mb-2">
                                    <p class="text-muted">Current Front Image:</p>
                                    <img src="@Model.IDImageFrontPath" alt="Current ID Front" class="img-thumbnail" style="max-height: 150px;" />
                                </div>
                            }
                            <label for="IDImageFront" class="form-label">ID Front Image (Leave empty to keep current)</label>
                            <input type="file" id="IDImageFront" name="IDImageFront" class="form-control" accept="image/*" />
                            <small class="form-text text-muted">Upload new ID front image</small>
                        </div>
                        <div class="col-md-6 mb-3">
                            @if (!string.IsNullOrEmpty(Model.IDImageBackPath))
                            {
                                <div class="mb-2">
                                    <p class="text-muted">Current Back Image:</p>
                                    <img src="@Model.IDImageBackPath" alt="Current ID Back" class="img-thumbnail" style="max-height: 150px;" />
                                </div>
                            }
                            <label for="IDImageBack" class="form-label">ID Back Image (Leave empty to keep current)</label>
                            <input type="file" id="IDImageBack" name="IDImageBack" class="form-control" accept="image/*" />
                            <small class="form-text text-muted">Upload new ID back image</small>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Update Client</button>
                        <a href="@Url.Action("Clients", "Dashboard")" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
