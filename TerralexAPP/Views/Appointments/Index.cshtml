@model IEnumerable<TerralexApp.Models.Appointment>
@{
    Layout = "_DashboardLayout";
    var staffDict = ViewBag.Staffs as Dictionary<int, string> ?? new Dictionary<int, string>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0 text-gray-800">Appointments Schedule</h1>
        <p class="text-muted small mb-0">Manage legal consultations, contract sign-offs, and court meetings.</p>
    </div>
    <a asp-action="Create" class="btn btn-premium btn-premium-primary">
        <i class="bi bi-calendar-plus-fill"></i> New Appointment
    </a>
</div>

<!-- Filtering Panel -->
<div class="form-card mb-4 py-3">
    <form method="get" class="row g-3 align-items-end">
        <div class="col-md-4">
            <label class="form-label-premium">Filter by Client</label>
            <select name="clientId" class="form-select form-control-premium" asp-items="ViewBag.Clients">
                <option value="">-- All Clients --</option>
            </select>
        </div>
        <div class="col-md-4">
            <label class="form-label-premium">Meeting Type</label>
            <select name="type" class="form-select form-control-premium">
                <option value="">-- All Types --</option>
                <option value="Consultation">Consultation</option>
                <option value="Contract Signing">Contract Signing</option>
                <option value="Court Hearing">Court Hearing</option>
                <option value="Document Review">Document Review</option>
            </select>
        </div>
        <div class="col-md-4 d-flex gap-2">
            <button type="submit" class="btn btn-premium btn-premium-secondary w-100">
                <i class="bi bi-funnel-fill"></i> Filter
            </button>
            <a asp-action="Index" class="btn btn-premium btn-premium-secondary w-100">
                <i class="bi bi-arrow-counterclockwise"></i> Reset
            </a>
        </div>
    </form>
</div>

<!-- Appointments Table Card -->
<div class="table-card">
    <div class="p-3 bg-light border-bottom d-flex align-items-center justify-content-between">
        <h6 class="mb-0 fw-bold"><i class="bi bi-calendar3 text-primary me-2"></i>Scheduled Meetings</h6>
        <span class="badge bg-primary rounded-pill">@Model.Count() Total</span>
    </div>
    <table class="table-premium">
        <thead>
            <tr>
                <th>Title / Type</th>
                <th>Client</th>
                <th>Assigned Lawyer</th>
                <th>Date & Time</th>
                <th>Location</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="6" class="text-center py-5 text-muted">
                        <i class="bi bi-calendar-x" style="font-size: 3rem; display: block; margin-bottom: 1rem;"></i>
                        No appointments found matching search criteria.
                    </td>
                </tr>
            }
            else
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="fw-bold">@item.Title</div>
                            <span class="badge-premium @(item.AppointmentType switch {
                                "Consultation" => "badge-info",
                                "Contract Signing" => "badge-success",
                                "Court Hearing" => "badge-danger",
                                _ => "badge-primary"
                            })">@item.AppointmentType</span>
                        </td>
                        <td>
                            <i class="bi bi-person-fill text-muted me-1"></i>
                            <a asp-controller="Dashboard" asp-action="ViewClient" asp-route-id="@item.ClientId" class="text-decoration-none fw-medium text-dark">
                                @item.Client?.FirstName @item.Client?.LastName
                            </a>
                        </td>
                        <td>
                            <i class="bi bi-briefcase-fill text-muted me-1"></i>
                            @(staffDict.TryGetValue(item.StuffId, out var staffName) ? staffName : "Unassigned")
                        </td>
                        <td>
                            <div class="fw-bold">@item.AppointmentDate.ToString("yyyy-MM-dd")</div>
                            <small class="text-muted"><i class="bi bi-clock me-1"></i>@item.AppointmentDate.ToString("hh:mm tt")</small>
                        </td>
                        <td>
                            <small class="text-muted"><i class="bi bi-geo-alt-fill me-1 text-danger"></i>@item.Location</small>
                        </td>
                        <td>
                            <div class="d-flex gap-2">
                                <a asp-action="Details" asp-route-id="@item.AppointmentId" class="btn btn-premium btn-premium-secondary btn-sm p-2" title="Details">
                                    <i class="bi bi-info-circle-fill"></i>
                                </a>
                                @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                                {
                                    <a asp-action="Edit" asp-route-id="@item.AppointmentId" class="btn btn-premium btn-premium-secondary btn-sm p-2 text-warning" title="Edit">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@item.AppointmentId" method="post" onsubmit="return confirm('Are you sure you want to delete this appointment?');" class="d-inline">
                                        <button type="submit" class="btn btn-premium btn-premium-secondary btn-sm p-2 text-danger" title="Delete">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
