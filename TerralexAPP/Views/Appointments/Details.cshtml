@model TerralexApp.Models.Appointment
@{
    Layout = "_DashboardLayout";
}

<div class="mb-4 d-flex justify-content-between align-items-center">
    <a asp-action="Index" class="btn btn-premium btn-premium-secondary">
        <i class="bi bi-arrow-left"></i> Back to List
    </a>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.AppointmentId" class="btn btn-premium btn-premium-primary bg-warning border-0 text-white">
            <i class="bi bi-pencil-square"></i> Edit
        </a>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="form-card mb-4">
            <div class="d-flex justify-content-between align-items-start border-bottom pb-3 mb-4">
                <div>
                    <span class="badge-premium @(Model.AppointmentType switch {
                        "Consultation" => "badge-info",
                        "Contract Signing" => "badge-success",
                        "Court Hearing" => "badge-danger",
                        _ => "badge-primary"
                    }) mb-2">@Model.AppointmentType</span>
                    <h2 class="text-dark fw-bold mb-0">@Model.Title</h2>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-12">
                    <h6 class="text-muted fw-bold text-uppercase small">Objective / Summary</h6>
                    <p class="fs-5 text-dark fw-medium">@Model.Summary</p>
                </div>

                <div class="col-12">
                    <h6 class="text-muted fw-bold text-uppercase small">Detailed Description</h6>
                    <div class="p-3 bg-light rounded text-dark" style="white-space: pre-wrap;">
                        @(string.IsNullOrEmpty(Model.Description) ? "No detailed description provided." : Model.Description)
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <!-- Meeting Info Sidebar Card -->
        <div class="stat-card mb-4" style="--card-accent: var(--primary);">
            <h5 class="fw-bold mb-4 border-bottom pb-2">Meeting Metadata</h5>
            
            <div class="d-flex flex-column gap-3">
                <div>
                    <label class="text-muted small fw-bold text-uppercase d-block">Scheduled Date & Time</label>
                    <span class="fw-bold text-dark"><i class="bi bi-calendar2-check-fill text-primary me-2"></i>@Model.AppointmentDate.ToString("dd MMM yyyy, hh:mm tt")</span>
                </div>

                <div>
                    <label class="text-muted small fw-bold text-uppercase d-block">Location / Medium</label>
                    <span class="text-dark"><i class="bi bi-geo-alt-fill text-danger me-2"></i>@Model.Location</span>
                </div>

                <div>
                    <label class="text-muted small fw-bold text-uppercase d-block">Client</label>
                    <a asp-controller="Dashboard" asp-action="ViewClient" asp-route-id="@Model.ClientId" class="text-decoration-none fw-bold text-primary">
                        <i class="bi bi-person-circle me-2"></i>@Model.Client?.FirstName @Model.Client?.LastName
                    </a>
                </div>

                <div>
                    <label class="text-muted small fw-bold text-uppercase d-block">Assigned Lawyer</label>
                    <span class="text-dark fw-medium"><i class="bi bi-briefcase-fill text-muted me-2"></i>@ViewBag.StaffName</span>
                </div>
            </div>
        </div>
    </div>
</div>
