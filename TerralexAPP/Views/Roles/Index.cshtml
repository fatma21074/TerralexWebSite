@model IEnumerable<ApplicationRole>
@{
    ViewData["Title"] = "Role Management";
    Layout = "_DashboardLayout";
}

<!-- Top Action Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <p class="text-muted small mb-0">Manage system roles, configure permissions, and view metadata.</p>
    </div>
    <a asp-action="Create" class="btn btn-premium btn-premium-primary">
        <i class="bi bi-plus-circle"></i> Create New Role
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-3 mb-4 shadow-sm border-0 d-flex align-items-center" role="alert">
        <i class="bi bi-check-circle-fill me-2 fs-5 text-success"></i>
        <div>
            @TempData["Success"]
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- Premium Table Card -->
<div class="table-card shadow-sm">
    <table class="table-premium">
        <thead>
            <tr>
                <th>Role Name</th>
                <th>Description</th>
                <th>Created By</th>
                <th>Created At</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model == null || !Model.Any())
            {
                <tr>
                    <td colspan="5" class="text-center py-5 text-muted">
                        <i class="bi bi-shield-slash display-4 mb-3"></i>
                        <p class="mb-0 fw-semibold">No Roles Defined</p>
                        <p class="text-muted small">Create a new system role to get started.</p>
                    </td>
                </tr>
            }
            else
            {
                @foreach (var role in Model)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <span class="badge-premium badge-primary px-3 py-2 fw-bold text-uppercase">@role.Name</span>
                            </div>
                        </td>
                        <td>
                            <span class="text-dark">@(string.IsNullOrEmpty(role.Description) ? "No description provided." : role.Description)</span>
                        </td>
                        <td>
                            <span class="text-muted"><i class="bi bi-person me-1"></i>@(role.CreatedBy ?? "System")</span>
                        </td>
                        <td>
                            <span class="text-muted"><i class="bi bi-calendar3 me-1"></i>@(role.CreatedAt == default ? "System Seeded" : role.CreatedAt.ToString("yyyy-MM-dd HH:mm"))</span>
                        </td>
                        <td class="text-end">
                            <div class="d-inline-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@role.Id" class="btn btn-premium btn-premium-secondary py-1 px-3 fs-7" title="Edit Role">
                                    <i class="bi bi-pencil-square"></i> Edit
                                </a>
                                <form asp-action="Delete" asp-route-id="@role.Id" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-premium btn-premium-secondary text-danger py-1 px-3 fs-7" onclick="return confirm('Are you sure you want to delete this role? This cannot be undone.')" title="Delete Role">
                                        <i class="bi bi-trash-fill"></i> Delete
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
