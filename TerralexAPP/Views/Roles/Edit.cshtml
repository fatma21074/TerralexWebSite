@model ApplicationRole
@{
    ViewData["Title"] = "Edit Role";
    Layout = "_DashboardLayout";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="form-card shadow-sm">
            <div class="d-flex align-items-center gap-3 mb-4">
                <div class="stat-card-icon" style="--card-accent: var(--primary); --card-accent-light: var(--primary-light); margin-bottom: 0;">
                    <i class="bi bi-pencil-square text-primary" style="font-size: 1.5rem;"></i>
                </div>
                <div>
                    <h3 class="mb-0 text-dark fw-bold">Edit Role Details</h3>
                    <p class="text-muted small mb-0">Update the name and descriptive purpose of this role.</p>
                </div>
            </div>

            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label asp-for="Name" class="form-label-premium">Role Name</label>
                    <input asp-for="Name" class="form-control-premium w-100" placeholder="e.g., Staff" required />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Description" class="form-label-premium">Description</label>
                    <textarea asp-for="Description" class="form-control-premium w-100" rows="4" placeholder="Briefly describe the permissions or responsibilities of this role..."></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-premium btn-premium-secondary">
                        <i class="bi bi-x-circle"></i> Cancel
                    </a>
                    <button type="submit" class="btn btn-premium btn-premium-primary">
                        <i class="bi bi-check-circle"></i> Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
